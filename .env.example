# Bitcoin Core RPC
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=rpcuser
BITCOIN_RPC_PASSWORD=rpcpassword

# Optional: set to wallet name to use /wallet/<name> endpoint.
# Leave empty to call the node endpoint only.
BITCOIN_RPC_WALLET=
BITCOIN_RPC_SCHEME=http
BITCOIN_RPC_TIMEOUT=15

# Web app
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=Private Bitcoin Core Wallet Frontend

# Optional Basic Auth for the web UI. Leave empty to disable.
WEB_AUTH_USER=
WEB_AUTH_PASSWORD=
